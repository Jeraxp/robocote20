# Spike Robocote 2.0 — variáveis de ambiente
# Copie para .env e preencha quando a Segfy provisionar as credenciais novas da Nova Jornada

PORT=3030
NODE_ENV=development

# Segfy — Nova Jornada (canônico do Robocote 2.0)
SEGFY_BASE_URL=https://api.automation.segfy.com
SEGFY_SOCKET_URL=https://socket-io.segfy.com
SEGFY_CLIENT_ID=
SEGFY_CLIENT_SECRET=

# Corretora-piloto RPI — token específico pra Nova Jornada oficial
RPI_CORRETORA_TOKEN=

# IA — Taskdun API (compatível com chat/completions)
TASKDUN_AI_BASE_URL=
TASKDUN_AI_CHAT_PATH=/v1/chat/completions
TASKDUN_AI_API_KEY=

# Papéis de modelo — Robocote 2.0
# - Extractor (mini): roteador de intenção e extração de slots em JSON. Tarefa estruturada, barata.
# - Dialog (5.3-chat-latest): voz da Vivi em turnos rotineiros (captura, confirmações curtas).
# - Analyst (5.4): voz da Vivi em modo Consulta, perfil/cobertura, objeções e mensagens complexas.
ROBOCOTE_EXTRACTOR_MODEL=gpt-5.4-mini
ROBOCOTE_DIALOG_MODEL=gpt-5.3-chat-latest
ROBOCOTE_ANALYST_MODEL=gpt-5.4

# Conhecimento/RAG — base curada de seguradoras, coberturas e fluxos
ROBOCOTE_EMBEDDING_MODEL=text-embedding-3-large
ROBOCOTE_VECTOR_STORE_ID=
ROBOCOTE_RAG_MAX_RESULTS=5

# Canal WhatsApp via Evolution API (self-hosted)
# Webhook inbound: POST {backend}/webhooks/evolution/incoming
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_WEBHOOK_SECRET=

# Identidade do tenant pra sessões WhatsApp (corretora-piloto)
ROBOCOTE_TENANT_ID=rpi

# URL pública do Robocote 2.0 (usada no link do Quote Room enviado pelo WhatsApp).
# Em dev com Cloudflare Tunnel: https://seu-tunnel.trycloudflare.com
# Em produção: https://app.robocote.com.br
ROBOCOTE_QUOTE_BASE_URL=
